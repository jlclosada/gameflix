# PostgreSQL connection string.
# Local example: postgres://postgres:postgres@localhost:5432/tierlist
# Render provides this automatically as DATABASE_URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tierlist

# Set to "true" when connecting to a managed Postgres that requires SSL (Render, Supabase).
PGSSL=false

# Port the API listens on.
PORT=4000

# Comma-separated list of allowed frontend origins for CORS.
# Use * to allow all (development only).
CORS_ORIGIN=*
